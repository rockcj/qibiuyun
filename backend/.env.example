# OfferGPT Backend Configuration Example
DATABASE_URL=sqlite+aiosqlite:///./offergpt.db
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
OPENAI_API_KEY=sk-your-openai-api-key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
ASR_PROVIDER=whisper
ASR_MODEL=base
TTS_PROVIDER=edge
# 默认 false：使用浏览器 speechSynthesis 朗读，响应更快
ENABLE_SERVER_TTS=false
# VAD：短句 0.5s 静音结束；长发言自动放宽句中停顿
VAD_SILENCE_MS=500
VAD_LONG_UTTERANCE_SILENCE_MS=1200
VAD_LONG_UTTERANCE_THRESHOLD_MS=2500
VAD_TURN_CONFIRM_MS=80
VAD_MIN_TURN_SECONDS=0.4
VAD_MAX_TURN_SECONDS=20
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
ENV=development
LOG_LEVEL=info

# 对象存储（火山引擎 TOS）；未配置时使用本地 ./storage/sessions/ 兜底
OBJECT_STORAGE_PROVIDER=local
# OBJECT_STORAGE_PROVIDER=tos
# TOS_ENDPOINT=tos-cn-guangzhou.volces.com
# TOS_REGION=cn-guangzhou
# TOS_BUCKET=your-bucket
# TOS_ACCESS_KEY_ID=your-access-key
# TOS_SECRET_ACCESS_KEY=your-secret-key
LOCAL_STORAGE_DIR=./storage
