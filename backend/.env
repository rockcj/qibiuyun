# OfferGPT Backend Configuration
# Database
DATABASE_URL=sqlite+aiosqlite:///./offergpt.db
# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/offergpt

# Redis
REDIS_URL=redis://localhost:6379/0
# Use in-memory cache when Redis is unavailable
REDIS_ENABLED=false

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-api-key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ASR/TTS
ASR_PROVIDER=whisper
TTS_PROVIDER=edge

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENV=development
LOG_LEVEL=info
