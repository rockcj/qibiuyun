# ============================================================================
# OfferGPT Docker 完整环境配置模板
# 使用方式: cp .env.docker .env.local
# 与 docker-compose.yml 中的 PostgreSQL/Redis 凭证一致
# ============================================================================

APP_ENV=development
APP_NAME=SpeakUp AI
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
WS_BASE_URL=ws://localhost:8000
DEFAULT_SCENE=interview
ENABLE_RESTAURANT_SCENE=true
ENABLE_MEETING_SCENE=true
REALTIME_LIGHT_CORRECTION_ENABLED=true
DEMO_MODE_ENABLED=true

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
SESSION_TOKEN_SECRET=offergpt-demo-session-secret
SESSION_TTL_SECONDS=7200
REQUEST_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO

# ---- 数据库（Docker PostgreSQL） ----
DATABASE_URL=postgresql://offergpt:offergpt123@localhost:5432/offergpt
DATABASE_JDBC_URL=jdbc:postgresql://localhost:5432/offergpt

# ---- 缓存（Docker Redis） ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/1

# ---- 对象存储（Docker 环境使用本地存储） ----
OBJECT_STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=./storage

# ---- LLM（请填入你的 DeepSeek API Key） ----
LLM_PROVIDER=deepseek
LLM_API_BASE_URL=https://api.deepseek.com/anthropic
LLM_MODEL=deepseek-v4-flash
LLM_REPORT_MODEL=deepseek-v4-pro
LLM_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
OPENAI_API_KEY=

# ---- ASR / TTS ----
ASR_PROVIDER=whisper
ASR_API_BASE_URL=
ASR_API_KEY=
ASR_MODEL=base

TTS_PROVIDER=edgeTts
TTS_API_BASE_URL=
TTS_API_KEY=
TTS_VOICE=en-US-JennyNeural
AI_PROVIDER_TIMEOUT_SECONDS=20

# ---- 前端环境变量 ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_DEFAULT_SCENE=interview
NEXT_PUBLIC_DEMO_MODE_ENABLED=true
NEXT_PUBLIC_ENABLE_RESTAURANT_SCENE=true
NEXT_PUBLIC_ENABLE_MEETING_SCENE=true

# ---- 降级与开关 ----
ENABLE_TEXT_INPUT_FALLBACK=true
ENABLE_MOCK_ASR=false
ENABLE_MOCK_TTS=false
ENABLE_PRESET_DEMO_DATA=true
ENABLE_REPORT_RETRY=true
REPORT_FALLBACK_MODE=basicTemplate
ENABLE_SERVER_TTS=false

# ---- JWT 认证 ----
JWT_SECRET_KEY=offergpt-demo-jwt-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- 测试配置 ----
TEST_DEFAULT_SCENE=interview
TEST_USE_MOCK_AI=true
TEST_USE_MOCK_AUDIO=true
TEST_DEMO_RESUME_PATH=./demo/resume.txt
TEST_DEMO_JD_PATH=./demo/jd.txt
